# Copy this file to .env and fill in your real values
# .env is in .gitignore and will NEVER be committed to GitHub

ETL_SMTP_HOST=smtp.gmail.com
ETL_SMTP_PORT=587
ETL_SMTP_USER=your_email@gmail.com
ETL_SMTP_PASS=your_app_password_here
ETL_NOTIFY_TO=recipient@company.com
ETL_NOTIFY_FROM=etl-pipeline@company.com
